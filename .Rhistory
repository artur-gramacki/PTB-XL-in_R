start <- 0
stop <- 10
# Which ECG to display
ecg_id <- 1
# to filter or not(see calling filters_coeff() function below)
filtering = TRUE
load("Y_with_diagnostic_superclass.RData")
load("d:\\Users\\GoogleDrive\\_EKG\\Y_with_diagnostic_superclass.RData")
load("d:\\Users\\GoogleDrive\\_EKG\\ECG_records500.RData")
