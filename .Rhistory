number_of_records <- 21799
ecg_length <- 10
lead_12 <- c("I", "II", "III", "AVR", "AVL", "AVF", "V1", "V2", "V3", "V4", "V5", "V6" )
# //////////////////////////////////////////////////////////////////////////////
# Params for plotting a sample ECG  ----
