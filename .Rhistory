# //////////////////////////////////////////////////////////////////////////////
# ECG sample plots ----
# //////////////////////////////////////////////////////////////////////////////
from <- start * sampling_rate
to <- stop * sampling_rate
range <- seq(from, to)
row <- which(Y$ecg_id == ecg_id)
fout <- filters.coeff(
fs = sampling_rate,
notch = c(49, 51),
lowpass = 40,
highpass = 1,
bandpass  = c(0.5, 40)
)
notch = fout$notch
low = fout$low
high = fout$high
bandpass = fout$bandpass
